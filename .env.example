APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:kgk/4DW1vEVy7aEvet5FPp5un6PIGe/so8H0mvoUtW0=

APP_NAME="InvoiceShelf"
APP_TIMEZONE=UTC
APP_URL=
APP_LOCALE=en

S3_COMPAT_KEY=invoiceshelf
S3_COMPAT_SECRET=invoiceshelf123
S3_COMPAT_REGION=us-east-1
S3_COMPAT_BUCKET=invoiceshelf-local
S3_COMPAT_ROOT=generated-pdfs

DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAIN=
TRUSTED_PROXIES="*"

# Dompdf: keep false so untrusted HTML in PDF notes cannot trigger outbound requests (SSRF).
# Set true only if you fully trust all PDF HTML and need remote images/CSS.
DOMPDF_ENABLE_REMOTE=false

OCR_BASE_URL=
OCR_API_KEY=
OCR_TIMEOUT=5
OCR_REQUIRED_FIELDS=invoice_number,date,amount,currency_code
OCR_TEMPLATE_HEALING_MAX_ATTEMPTS=3
OCR_DEBUG=true

# LLM provider for OCR fallback extraction and AI template generation
# Values: none | openrouter | ollama (default: none)
OCR_LLM_PROVIDER=none
# Legacy alias — ignored when OCR_LLM_PROVIDER is set explicitly
OCR_OPENROUTER_FALLBACK=false
OCR_AUTO_GENERATE_TEMPLATES=false

# OpenRouter settings (used when OCR_LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=
OPENROUTER_TEMPLATE_MODEL=
OPENROUTER_TIMEOUT=30
OPENROUTER_REQUIRE_ZDR=false
OPENROUTER_DISABLE_REASONING=false
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=
OPENROUTER_PDF_ENGINE=native
OPENROUTER_RATE_LIMIT_RETRIES=2
OPENROUTER_RATE_LIMIT_BACKOFF_MS=2000

# Ollama settings (used when OCR_LLM_PROVIDER=ollama)
# Point to a locally-running Ollama instance; host.docker.internal resolves to the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=
OLLAMA_TEMPLATE_MODEL=
OLLAMA_TIMEOUT=60
OLLAMA_MAX_PDF_PAGES=4
